# Copia este archivo a .env y rellena tus valores.

# --- Claude API (obligatorio) ---
# Consíguela en https://console.anthropic.com/  -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Modelos (opcional, estos son buenos defaults) ---
MODELO_BORRADOR=claude-sonnet-4-6
MODELO_CRITICO=claude-sonnet-4-6
MAX_LOOPS=2

# --- WhatsApp Cloud API (se llena cuando conectemos Meta) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=froy-verify-2026

# --- Green API (WhatsApp por QR; mejor configúralo desde el dashboard ⚙️ Conexión) ---
GREEN_ID_INSTANCE=
GREEN_API_TOKEN=
GREEN_API_URL=https://api.green-api.com

# --- Dashboard (pon una contraseña fuerte antes de exponerlo a internet) ---
PANEL_USER=admin
PANEL_PASS=          # ⚠ déjalo vacío SOLO en local; en el VPS pon una contraseña fuerte

# --- Ritmo humano (opcional; estos defaults funcionan bien) ---
HUMANIZAR=1              # 0 = desactiva tiempos/globos (responde de un jalón)
HUMANO_CPS=20           # caracteres por segundo al "escribir" (más bajo = más lento)
HUMANO_TOPE_GLOBO=6.5   # segundos máximos por globo
HUMANO_MAX_GLOBOS=3     # cuántos globos máximo por respuesta
