# Servicio del webhook de WhatsApp. Copiar a /etc/systemd/system/froy-webhook.service
[Unit]
Description=Froy - Webhook de WhatsApp
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/froy/src
EnvironmentFile=/opt/froy/.env
ExecStart=/opt/froy/.venv/bin/gunicorn --workers 2 --threads 4 --timeout 60 --bind 127.0.0.1:8000 server:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
